      m_Calls: []
  m_text: "\u041F\u0440\u044F\u043C\u043E \u0433\u0434\u0435 \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u044C\u0441\u044F
    \u042D\u0422\u041E\u0422 \u0442\u0435\u043A\u0441\u0442 \u0431\u0443\u0434\u0435\u0442
    \u041A\u0430\u0444\u0435-\u0411\u0438\u0441\u0442\u0440\u043E, \u043A\u0443\u0434\u0430
    \u043D\u0443\u0436\u043D\u043E \u0431\u0443\u0434\u0435\u0442 \u0437\u0430\u0439\u0442\u0438.\n\u041D\u043E
    \u043E\u043D\u0430 \u0437\u0430\u043F\u0435\u0440\u0442\u0430, \u043F\u043E\u043F\u0440\u043E\u0431\u0443\u0439\u0442\u0435
    \u043F\u043E\u0445\u043E\u0434\u0438\u0442\u044C \u043F\u043E \u0443\u0440\u043E\u0432\u043D\u044E
    \u0438 \u043D\u0430\u0439\u0442\u0438 \u0432\u043B\u0430\u0434\u0435\u043B\u044C\u0446\u0430\n\u041A\u0430\u043A
    \u043D\u0430\u0448\u043B\u0438 \u0435\u0433\u043E, \u0438\u0434\u0438\u0442\u0435
    \u0447\u0435\u0440\u0435\u0437 \u0430\u0440\u043A\u0443 \u0441\u043F\u0440\u0430\u0432\u0430
    ->\n\u0412 \u0431\u0438\u0441\u0442\u0440\u043E \u0431\u0443\u0434\u0435\u0442
    \u0442\u043E\u0440\u0433\u043E\u0432\u044B\u0439 \u0430\u0432\u0442\u043E\u043C\u0430\u0442
    \u043F\u043E \u043F\u0440\u043E\u0434\u0430\u0436\u0435 \u0448\u0430\u0443\u0440\u043C\u044B
    (\u044D\u0442\u043E \u0442\u0443\u0442\u043E\u0440\u0438\u0430\u043B \u043F\u043E\u043A\u0443\u043F\u043A\u0438
    \u043F\u0440\u0435\u0434\u043C\u0435\u0442\u043E\u0432)"
