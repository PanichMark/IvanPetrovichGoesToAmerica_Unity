  m_text: "\u042D\u0442\u0430 \u043B\u043E\u043A\u0430\u0446\u0438\u044F \"\u0414\u043E\u0445\u043E\u0434\u043D\u044B\u0439
    \u0434\u043E\u043C \u0433\u043E\u0441\u043F\u043E\u0434\u0438\u043D\u0430 \u0420\u043E\u0441\u0442\u043E\u0432\u0449\u0438\u043A\u043E\u0432\u0430\"\n\u041C\u043D\u043E\u0433\u043E\u043A\u0432\u0430\u0440\u0442\u0438\u0440\u043D\u044B\u0439
    \u0436\u0438\u043B\u043E\u0439 \u0434\u043E\u043C\n\u0422\u0443\u0442 \u0431\u0443\u0434\u0435\u0442
    2 - 3 \u044D\u0442\u0430\u0436\u0430\n\u043F\u043E\u043A\u0430 GreyBox \u0432\u0435\u0440\u0441\u0438\u044F
    \u043D\u0435 \u0434\u043E\u0434\u0435\u043B\u0430\u043D\u0430\n\u0418\u0437 \u0434\u043E\u043C\u0430
    \u043F\u043E\u043F\u0430\u0434\u0430\u0435\u043C \u0432 \u0441\u043B\u0435\u0434\u0443\u044E\u0449\u0443\u044E
    \u043B\u043E\u043A\u0430\u0446\u0438\u044E ->"
