  m_text: "\u0412 \u0434\u043E\u0445\u043E\u0434\u043D\u043E\u043C \u0434\u043E\u043C\u0435
    \u0435\u0441\u0442\u044C 2 \u0432\u0438\u0434\u0430 \u0442\u043E\u0440\u0433\u043E\u0432\u044B\u0445
    \u0430\u0432\u0442\u043E\u043C\u0430\u0442\u0430\u0445, \u0440\u0430\u0441\u043F\u043E\u043B\u043E\u0436\u0435\u043D\u043D\u044B\u0445
    \u0432 \u043A\u043E\u0440\u0438\u0434\u043E\u0440\u0430\u0445 \u043F\u043E\u0434\u044A\u0435\u0437\u0434\u0430:
    \u0434\u043B\u044F \u043F\u043E\u043A\u0443\u043F\u043A\u0438 \u043F\u0430\u0442\u0440\u043E\u043D\u043E\u0432
    \u0438 \u0448\u0430\u0443\u0440\u043C\u044B(\u0445\u0438\u043B)\n\u0422\u0430\u043A\u0436\u0435
    \u043F\u043E\u0434 \u043A\u043E\u043D\u0435\u0446 \u043B\u043E\u043A\u0430\u0446\u0438\u0438
    \u043C\u044B \u043F\u043E\u043B\u0443\u0447\u0438\u043C \u0441\u0435\u0431\u0435
    3\u0435 \u043E\u0440\u0443\u0436\u0438\u0435 - \u0430\u0431\u043E\u0440\u0434\u0430\u0436\u043D\u044B\u0439
    \u0430\u0440\u0431\u0430\u043B\u0435\u0442, \u0437\u0430\u0431\u0440\u0430\u0432
    \u0435\u0433\u043E \u0441 \u0442\u0440\u0443\u043F\u0430 \u043F\u043E\u0436\u0430\u0440\u043D\u043E\u0433\u043E"
